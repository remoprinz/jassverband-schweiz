# ====================================
# JVS (Jassverband Schweiz) Environment Variables
# ====================================

# Base URL (für Stripe Redirects)
NEXT_PUBLIC_BASE_URL=https://jassverband.ch

# ====================================
# STRIPE
# ====================================
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable Key (Client-side, starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret Key (Server-side, starts with sk_)
STRIPE_SECRET_KEY=sk_test_...

# Webhook Secret (from Stripe Dashboard > Webhooks)
# Get this after creating webhook endpoint: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ====================================
# FIREBASE ADMIN SDK
# ====================================
# Service Account Key als JSON-String (für Vercel: als einzelne Env-Variable)
# Download von: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Den gesamten JSON-Inhalt als Wert setzen (einzeilig):
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"jasstafel","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@jasstafel.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Fallback: Nur Project ID (reicht für Emulator/Local, nicht für Produktion)
# FIREBASE_PROJECT_ID=jasstafel

# ====================================
# RESEND (Email Service)
# ====================================
# Get API Key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Absender-Adresse (muss in Resend verifiziert sein)
EMAIL_FROM=Jassverband Schweiz <noreply@jassverband.ch>

# Empfänger für Kontaktformular
CONTACT_EMAIL=info@jassverband.ch

# ====================================
# SETUP INSTRUCTIONS
# ====================================
#
# 1. Firebase Service Account:
#    - Firebase Console > Project Settings > Service Accounts
#    - "Generate New Private Key" klicken
#    - JSON-Inhalt als FIREBASE_SERVICE_ACCOUNT_KEY setzen
#    - Auf Vercel: Settings > Environment Variables > hinzufügen
#
# 2. Stripe Account:
#    - https://stripe.com Account erstellen
#    - API Keys kopieren aus Dashboard
#    - Webhook erstellen:
#      Endpoint: https://jassverband.ch/api/webhooks/stripe
#      Events: checkout.session.completed, payment_intent.payment_failed
#    - Für lokales Testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
#
# 3. Resend:
#    - https://resend.com Account erstellen
#    - Domain verifizieren (jassverband.ch)
#    - API Key erstellen
#
# 4. .env.local erstellen:
#    cp .env.example .env.local
#    # Dann alle Werte eintragen
