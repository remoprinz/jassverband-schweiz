# ====================================
# JVS (Jassverband Schweiz) Environment Variables
# ====================================

# Base URL (für Stripe Redirects)
NEXT_PUBLIC_BASE_URL=https://jassverband.ch

# ====================================
# STRIPE
# ====================================
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable Key (Client-side, starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret Key (Server-side, starts with sk_)
STRIPE_SECRET_KEY=sk_test_...

# Webhook Secret (from Stripe Dashboard > Webhooks)
# Get this after creating webhook endpoint: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ====================================
# FIREBASE (für Membership-Aktivierung)
# ====================================
# Cloud Functions URL (europe-west1)
FIREBASE_FUNCTIONS_URL=https://europe-west1-jasstafel.cloudfunctions.net

# Service Token für Server-to-Server Auth (optional)
# FIREBASE_SERVICE_TOKEN=...

# ====================================
# SETUP INSTRUCTIONS
# ====================================
# 
# 1. Stripe Account erstellen: https://stripe.com
# 2. API Keys kopieren aus Dashboard
# 3. Webhook erstellen:
#    - Endpoint: https://jassverband.ch/api/webhooks/stripe
#    - Events: checkout.session.completed, payment_intent.succeeded
# 4. .env.local erstellen mit den echten Werten
# 5. Für lokales Testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
